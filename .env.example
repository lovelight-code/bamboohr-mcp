# bamboohr-mcp configuration
#
# Two supported shapes:
#
# 1) Direct (local stdio talking straight to BambooHR):
#    set a token + company subdomain. The client attaches HTTP Basic auth.
BAMBOO_API_TOKEN=your_api_token_here
BAMBOO_COMPANY_DOMAIN=your_company_subdomain

# 2) Proxied / credential-free (recommended for shared/sensitive use):
#    point BAMBOO_BASE_URL at a loopback token-proxy that injects
#    Authorization on every request. With this set, BAMBOO_API_TOKEN is
#    optional and this process holds no credential.
# BAMBOO_BASE_URL=http://127.0.0.1:7339

# Optional: restrict which tools register (comma/space-separated allowlist).
# Unset = all tools. Lets you switch tools on/off by config alone — e.g. keep
# tools whose BambooHR OAuth scope you didn't grant switched off so the agent
# is never offered one that 403s.
# BAMBOO_ENABLED_TOOLS=get-employee,get-employee-photo,get-employee-directory,estimate-time-off-balance,get-time-off-requests,get-whos-out,get-meta-fields

# Optional: debug logging to stderr (never logs auth or response bodies;
# params may contain ids — keep off in production).
DEBUG=false
